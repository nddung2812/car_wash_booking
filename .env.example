# Site / SEO
NEXT_PUBLIC_SITE_URL=https://logancarwash.com.au
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Cloudinary image CDN (Cloudinary "fetch" mode — no upload required;
# Cloudinary pulls images from NEXT_PUBLIC_SITE_URL and serves WebP/AVIF
# variants automatically via f_auto/q_auto). Leave blank in dev to fall
# back to direct local image serving.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Database (Neon)
DATABASE_URL=
